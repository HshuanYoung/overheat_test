[Unit]
Description=Overheat API and Socket.IO server
After=network.target mariadb.service

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/overheat_test
Environment=NODE_ENV=production
Environment=PORT=3001
Environment=DB_CONNECTION_LIMIT=4
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
